{
  "spec": "equanim/0.1",
  "meta": {
    "title": "Bouncing Ball",
    "duration": 5.0,
    "width": 600,
    "height": 450,
    "fps": 60,
    "coordinate_system": "cartesian",
    "origin": "center"
  },
  "variables": {
    "g": {
      "label": "Gravity (units/s²)",
      "default": 500,
      "min": 50,
      "max": 2000,
      "step": 10
    },
    "h0": {
      "label": "Drop height",
      "default": 160,
      "min": 10,
      "max": 210,
      "step": 5
    },
    "decay": {
      "label": "Energy loss (1/s)",
      "default": 0.35,
      "min": 0,
      "max": 2,
      "step": 0.05
    },
    "radius": {
      "label": "Ball radius",
      "default": 22,
      "min": 5,
      "max": 60,
      "step": 1
    }
  },
  "scene": {
    "id": "root",
    "objects": [
      {
        "id": "ball",
        "type": "circle",
        "style": {
          "fill": "#ff6644",
          "stroke": "#ff9977",
          "stroke_width": 2
        },
        "equations": {
          "cx": "0",
          "cy": "-190 + radius + B(t * d)",
          "r": "radius"
        },
        "functions": {
          "p": {
            "args": ["ts"],
            "body": "(ts / sqrt(2 * h0 / g)) % 1"
          },
          "H": {
            "args": ["ts"],
            "body": "h0 * exp(-decay * ts)"
          },
          "B": {
            "args": ["ts"],
            "body": "H(ts) * 4 * p(ts) * (1 - p(ts))"
          }
        },
        "timeline": { "start": 0.0, "end": 1.0 }
      },
      {
        "id": "floor",
        "type": "line",
        "style": {
          "stroke": "#ffffff55",
          "stroke_width": 2
        },
        "equations": {
          "x1": "-270",
          "y1": "-190",
          "x2": "270",
          "y2": "-190"
        },
        "timeline": { "start": 0.0, "end": 1.0 }
      }
    ]
  }
}
