{
  "spec": "equanim/0.1",
  "meta": {
    "title": "Bouncing Ball",
    "duration": 8.0,
    "width": 600,
    "height": 450,
    "fps": 60,
    "coordinate_system": "cartesian",
    "origin": "center"
  },
  "variables": {
    "g": {
      "label": "Gravity (units/s²)",
      "default": 500,
      "min": 50,
      "max": 2000,
      "step": 10
    },
    "e": {
      "label": "Restitution",
      "default": 0.75,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01
    },
    "radius": {
      "label": "Ball radius",
      "default": 22,
      "min": 5,
      "max": 60,
      "step": 1
    }
  },
  "scene": {
    "id": "root",
    "objects": [
      {
        "id": "phys",
        "type": "ode_system",
        "state": { "y": 180.0, "vy": 0.0 },
        "derivatives": {
          "y": "vy",
          "vy": "-g"
        },
        "events": [
          {
            "condition": "y - (-190 + radius)",
            "direction": "falling",
            "mutations": { "vy": "-e * vy" }
          }
        ],
        "solver": "rk4",
        "step": 0.001
      },
      {
        "id": "ball",
        "type": "circle",
        "style": {
          "fill": "#ff6644",
          "stroke": "#ff9977",
          "stroke_width": 2
        },
        "equations": {
          "cx": "0",
          "cy": "phys_y(t * d)",
          "r": "radius"
        },
        "timeline": { "start": 0.0, "end": 1.0 }
      },
      {
        "id": "floor",
        "type": "line",
        "style": {
          "stroke": "#ffffff55",
          "stroke_width": 2
        },
        "equations": {
          "x1": "-270",
          "y1": "-190",
          "x2": "270",
          "y2": "-190"
        },
        "timeline": { "start": 0.0, "end": 1.0 }
      }
    ]
  }
}
