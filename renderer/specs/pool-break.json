{
  "spec": "equanim/0.1",
  "meta": {
    "title": "Pool Break",
    "duration": 8.0,
    "width": 800,
    "height": 400,
    "fps": 60,
    "coordinate_system": "cartesian",
    "origin": "center",
    "background": "#1a6b2f"
  },
  "variables": {
    "cue_speed": {
      "label": "Cue Speed",
      "default": 600,
      "min": 200,
      "max": 1000,
      "step": 10
    },
    "angle": {
      "label": "Angle (deg)",
      "default": 2,
      "min": -15,
      "max": 15,
      "step": 0.5
    },
    "restitution": {
      "label": "Restitution",
      "default": 0.85,
      "min": 0.3,
      "max": 1.0,
      "step": 0.05
    },
    "friction": {
      "label": "Friction",
      "default": 60,
      "min": 0,
      "max": 200,
      "step": 5
    }
  },
